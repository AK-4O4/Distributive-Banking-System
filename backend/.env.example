# ── MongoDB Atlas Connection URIs ─────────────────────────────────────────────
# Each branch should point to a separate Atlas cluster for true distribution.
# For local dev, you can point all to the same cluster with different DB names.

MONGO_URI_NORTH=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_SOUTH=mongodb+srv://<user>:<password>@cluster1.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_EAST=mongodb+srv://<user>:<password>@cluster2.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_WEST=mongodb+srv://<user>:<password>@cluster3.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_COORDINATOR=mongodb+srv://<user>:<password>@cluster4.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Security ──────────────────────────────────────────────────────────────────
# All API requests require this key in the X-API-Key header.
# Change this to a strong random value in production.
API_KEY=dev-secret-key-change-in-production
