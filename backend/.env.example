# ── MongoDB Atlas Connection URIs ─────────────────────────────────────────────
#
# OPTION A — True distributed setup (production / ideal demo):
#   Each URI points to a separate Atlas cluster (one per branch group).
#
# OPTION B — Single-cluster mode (dev / demo with one free-tier account):
#   All URIs point to the same cluster.
#   The coordinator uses separate DATABASE names inside that one cluster:
#     • db_branch_north
#     • db_branch_south
#     • db_branch_east
#     • db_branch_west
#     • db_branch_central
#     • db_coordinator_ledger  ← for the 2PC transaction log
#   Data is fully isolated; all distributed concepts still apply.

MONGO_URI_NORTH=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_SOUTH=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_EAST=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_WEST=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URI_COORDINATOR=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# ── Security ──────────────────────────────────────────────────────────────────
# All API requests require this key in the X-API-Key header.
# Change this to a strong random value in production.
API_KEY=dev-secret-key-change-in-production
